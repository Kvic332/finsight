{
  "expo": {
    "name": "Kvic7 FinSight",
    "slug": "finsight-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0F0E"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0F0E"
      },
      "package": "com.kvic.finsightmobile",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kvic.finsightmobile"
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "enableJetifier": true
          }
        }
      ],
      "./plugins/withAndroidExclusion",
      "./plugins/withNativeBankCapture"
    ],
    "extra": {
      "eas": {
        "projectId": "4e195f96-97a2-4d5c-b6e0-2275d8439323"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4e195f96-97a2-4d5c-b6e0-2275d8439323"
    }
  }
}
